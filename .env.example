APP_NAME=call-worker
APP_ENV=local
APP_VERSION=dev
APP_LOG_LEVEL=info

HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=30s

WORKER_ENABLED=true
WORKER_ID=local-worker-1
WORKER_POLL_INTERVAL=5s
WORKER_CONCURRENCY=2
WORKER_JOB_TIMEOUT=45m
WORKER_CLAIM_BATCH_SIZE=1
WORKER_INCLUDE_RAW_RESPONSES=false

STORAGE_MAX_AUDIO_BYTES=314572800

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me
SUPABASE_SCHEMA=public
SUPABASE_AUDIO_BUCKET=call-audio
SUPABASE_RAW_BUCKET=call-raw
SUPABASE_REPORTS_BUCKET=call-reports

SBER_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth

SALUTE_AUTH_HEADER_SCHEME=Basic
SALUTE_AUTH_KEY=change-me
SALUTE_SCOPE=SALUTE_SPEECH_PERS
SALUTE_UPLOAD_URL=https://smartspeech.sber.ru/rest/v1/data:upload
SALUTE_RECOGNIZE_URL=https://smartspeech.sber.ru/rest/v1/speech:async_recognize
SALUTE_TASK_STATUS_URL=https://smartspeech.sber.ru/rest/v1/task:get
SALUTE_DOWNLOAD_URL=https://smartspeech.sber.ru/rest/v1/data:download
SALUTE_POLL_INTERVAL=5s
SALUTE_POLL_TIMEOUT=25m
SALUTE_LANGUAGE=ru-RU
SALUTE_MODEL=general
# Optional: force SaluteSpeech RecognitionOptions.audio_encoding (MP3, PCM_S16LE, FLAC, OPUS, …). If empty, inferred from file name / MIME type.
SALUTE_AUDIO_ENCODING=
SALUTE_SAMPLE_RATE=8000
SALUTE_CHANNELS_COUNT=2
SALUTE_SPEAKER_SEPARATION_ENABLED=true
SALUTE_SPEAKERS_COUNT=2

GIGACHAT_AUTH_KEY=change-me
# Must match your GigaChat Studio project type (NGW code 7 = mismatch): GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Optional; defaults to SBER_OAUTH_URL if unset.
# GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.2

TLS_INSECURE_SKIP_VERIFY=false
